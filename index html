            border-bottom-color: var(--gold-primary);
            display: flex; justify-content: center; align-items: center;
            margin-bottom: 25px; animation: spinGlow 2s linear infinite;
        }
        .loader-image-frame img { 
            width: 100px; height: auto; object-fit: contain; border-radius: 50%;
            animation: counterSpinPulse 2s linear infinite;
        }
        @keyframes spinGlow { 100% { transform: rotate(360deg); } }
        @keyframes counterSpinPulse { 100% { transform: rotate(-360deg) scale(0.95); } }

        /* الرأس (Header) */
        header {
